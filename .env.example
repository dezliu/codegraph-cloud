# Database
DATABASE_URL=postgresql://codegraph:codegraph_dev@localhost:5432/codegraph_cloud

# API
API_PORT=3000
API_HOST=0.0.0.0

# Worker
WORKER_PORT=3001
DATA_DIR=./data

# MCP Server
MCP_PORT=3002

# Admin
ADMIN_PORT=3003
# Paste the key from `pnpm seed:admin`, or configure in Admin → Settings
NEXT_PUBLIC_ADMIN_API_KEY=

# Git
GIT_WORKSPACE_DIR=./data/git-workspace
GIT_MIRROR_DIR=./data/git-mirrors

# Encryption (generate a real one for production)
ENCRYPTION_KEY=dev-only-change-in-production-32b

# Webhook base URL (for GitLab webhook registration)
WEBHOOK_BASE_URL=http://localhost:3000

# Worker → MCP cache invalidation (internal)
MCP_INTERNAL_URL=http://localhost:3002

# Optional S3/MinIO index persistence (leave S3_BUCKET empty to disable)
# S3_BUCKET=codegraph-indexes
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true
