{
  "name": "codegraph-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud-hosted code knowledge graph platform with MCP API",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @codegraph-cloud/db-schema migrate",
    "db:generate": "pnpm --filter @codegraph-cloud/db-schema generate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
